VITE_API_BASE_URL=http://localhost:3011/api

# Harus SAMA PERSIS dengan BACKEND_API_KEY di csc-backend/.env, kalau
# backend sudah diaktifkan proteksi API key-nya. Nilai ini nempel di
# hasil build frontend (bisa dilihat siapa saja lewat browser dev tools),
# jadi ini bukan "rahasia" -- fungsinya cuma nyaring bot/scanner acak,
# BUKAN pengganti login/autentikasi user.
VITE_API_KEY=

# .env INI DIBACA OTOMATIS OLEH docker-compose.yml (harus di folder yang
# sama). Copy jadi ".env" lalu ganti SEMUA password di bawah dengan yang
# acak & kuat sebelum dipentest / dipakai di luar laptop kamu sendiri.
#
# Generate password acak, contoh:
#   openssl rand -base64 24

POSTGRES_DB=csc_dashboard
POSTGRES_USER=csc_user
POSTGRES_PASSWORD=ganti_dengan_password_acak_yang_kuat

# Kunci API backend (X-API-Key). Harus SAMA PERSIS dengan BACKEND_API_KEY
# di csc-backend/.env dan VITE_API_KEY di csc-dashboard/.env.
BACKEND_API_KEY=ganti_dengan_string_acak_yang_panjang

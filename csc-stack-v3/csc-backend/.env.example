PORT=3001

# Kunci rahasia buat autentikasi endpoint /api/* (dicek lewat header
# X-API-Key). WAJIB diisi dengan string acak yang panjang & unik sebelum
# backend ini di-pentest / dipakai di luar localhost.
# Generate contoh: openssl rand -hex 32
BACKEND_API_KEY=

# Origin (URL) frontend yang diizinkan manggil API ini lewat CORS.
# Pisahkan dengan koma kalau lebih dari satu, contoh:
# CORS_ORIGIN=http://localhost:5183,https://dashboard.perusahaan.com
CORS_ORIGIN=http://localhost:5183

# GOWA (go-whatsapp-web-multidevice) - https://github.com/aldinokemal/go-whatsapp-web-multidevice
#
# CATATAN: kalau backend ini dijalankan lewat `docker compose up` (root
# project), nilai ini OTOMATIS di-override jadi "http://whatsapp:3000"
# (nama service di docker-compose.yml), jadi tidak perlu diubah manual.
# Nilai di bawah ini cuma dipakai kalau kamu jalankan backend LANGSUNG di
# host (npm run dev, tanpa Docker) sambil GOWA jalan lokal di port 3000.
GOWA_BASE_URL=http://localhost:3000

# Isi HANYA kalau GOWA kamu dijalankan dengan --basic-auth=user:pass
GOWA_BASIC_AUTH_USER=
GOWA_BASIC_AUTH_PASS=

# Isi HANYA kalau GOWA kamu setup multi-device dan device yang mau dipakai
# bukan device default/satu-satunya. Kalau cuma 1 device yang login, kosongkan saja.
GOWA_DEVICE_ID=

# PostgreSQL. Sama seperti GOWA_BASE_URL di atas: kalau dijalankan lewat
# `docker compose up`, DB_HOST otomatis di-override jadi "postgres" (nama
# service). Nilai 127.0.0.1 di bawah ini cuma dipakai kalau backend
# dijalankan langsung di host tanpa Docker.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=csc_user
DB_PASSWORD=csc_password
DB_NAME=csc_dashboard
